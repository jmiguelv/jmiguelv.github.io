---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import ProjectItem from "../components/ProjectItem.astro";
import PublicationItem from "../components/PublicationItem.astro";

const projectEntries = await getCollection("projects");
const projects = projectEntries
    .map((e) => e.data)
    .sort((a, b) => {
        const ae = a.endYear ?? a.startYear ?? -Infinity;
        const be = b.endYear ?? b.startYear ?? -Infinity;
        if (be !== ae) return be - ae;
        const as = a.startYear ?? -Infinity;
        const bs = b.startYear ?? -Infinity;
        if (bs !== as) return bs - as;
        return a.title.localeCompare(b.title);
    });

const publicationEntries = await getCollection("publications");
const publications = publicationEntries
    .map((e) => e.data)
    .sort((a, b) => b.year - a.year);

// Group publications by year (descending) for collapsible year sections.
const publicationsByYear = new Map<number, typeof publications>();
for (const pub of publications) {
    const group = publicationsByYear.get(pub.year) ?? [];
    group.push(pub);
    publicationsByYear.set(pub.year, group);
}
const publicationGroups = [...publicationsByYear.entries()]
    .sort((a, b) => b[0] - a[0])
    .map(([year, items]) => ({ year, items }));
---

<Base title="Miguel Vieira — Research Software Engineer">
    <header class="site">
        <input
            type="checkbox"
            id="theme-toggle"
            class="theme-input"
            aria-label="Toggle dark mode"
        />
        <h1 class="name">
            Miguel<label
                for="theme-toggle"
                class="sep"
                title="Toggle dark mode"></label
            ><i>Vieira</i>
        </h1>
        <p class="role">
            Research Software Engineer
            <span class="sep">+</span>
            Digital Humanities
        </p>
    </header>

    <main>
        <section class="about" aria-labelledby="about">
            <h2 id="about">About</h2>
            <p>
                I am a Principal Research Software Engineer with over fifteen
                years of experience building research software in academic and
                cross-disciplinary settings. My work spans digital humanities
                and computational social science.
            </p>
            <p>
                I have contributed to editions, archives, prosopographies, and
                computational projects across history, literature, classics,
                and film studies — at the intersection of engineering and
                humanistic inquiry. My technical work covers web applications,
                data pipelines, natural language processing, applied machine
                learning, multimodal AI, and retrieval-augmented generation.
            </p>
            <p>
                I am also interested in open-source research tools, training
                researchers in computational methods, and leading small
                engineering teams on funded research projects with academic and
                industry partners. I previously worked at King's Digital Lab,
                King's College London, as Principal Research Software Engineer.
            </p>
        </section>

        <section aria-labelledby="projects">
            <h2 id="projects">Projects</h2>
            <ul class="projects-list">
                {
                    projects.map((p) => (
                        <li>
                            <ProjectItem
                                title={p.title}
                                links={p.links}
                                startYear={p.startYear}
                                endYear={p.endYear}
                                summary={p.summary}
                            />
                        </li>
                    ))
                }
            </ul>
        </section>

        <section aria-labelledby="research">
            <h2 id="research">Research</h2>
            {
                publications.length === 0 ? (
                    <p>
                        Selected publications will appear here. In the meantime,
                        see my full{" "}
                        <a
                            href="https://kclpure.kcl.ac.uk/portal/en/persons/jose.m.vieira/publications/"
                            rel="noopener"
                        >
                            profile on KCL Pure
                        </a>
                        .
                    </p>
                ) : (
                    <div class="publication-years">
                        {publicationGroups.map((g, i) => (
                            <details class="year-group" open={i === 0}>
                                <summary>
                                    <span class="marker">+</span>
                                    <span class="year-label">
                                        <span class="title">{g.year}</span>
                                        <span class="count">
                                            {" · "}
                                            {g.items.length}{" "}
                                            {g.items.length === 1
                                                ? "publication"
                                                : "publications"}
                                        </span>
                                    </span>
                                </summary>
                                <div class="body">
                                    <ul class="publications-list">
                                        {g.items.map((p) => (
                                            <PublicationItem
                                                title={p.title}
                                                authors={p.authors}
                                                year={p.year}
                                                venue={p.venue}
                                                url={p.url}
                                            />
                                        ))}
                                    </ul>
                                </div>
                            </details>
                        ))}
                    </div>
                )
            }
        </section>
    </main>

    <footer class="site">
        <a href="https://www.linkedin.com/in/jmiguelv/" rel="noopener"
            >LinkedIn</a
        >
        <a href="https://github.com/jmiguelv" rel="noopener">GitHub</a>
        <span class="colophon">
            Built with <a href="https://astro.build" rel="noopener">Astro</a>
        </span>
    </footer>
</Base>
