---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import ProjectItem from "../components/ProjectItem.astro";
import PublicationItem from "../components/PublicationItem.astro";

const projectEntries = await getCollection("projects");
const projects = projectEntries
    .map((e) => e.data)
    .sort((a, b) => {
        const ay = a.startYear ?? -Infinity;
        const by = b.startYear ?? -Infinity;
        if (by !== ay) return by - ay;
        return a.title.localeCompare(b.title);
    });

const publicationEntries = await getCollection("publications");
const publications = publicationEntries
    .map((e) => e.data)
    .sort((a, b) => b.year - a.year);
---

<Base title="Miguel Vieira — Research Software Engineer">
    <header class="site">
        <input
            type="checkbox"
            id="theme-toggle"
            class="theme-input"
            aria-label="Toggle dark mode"
        />
        <h1 class="name">
            Miguel<label
                for="theme-toggle"
                class="sep"
                title="Toggle dark mode"
                role="button"
                tabindex="0">·</label
            ><i>Vieira</i>
        </h1>
        <p class="role">
            Research Software Engineer
            <span class="sep">✦</span>
            Digital Humanities
        </p>
    </header>

    <main>
        <section class="about" aria-labelledby="about">
            <h2 id="about">About <small>a brief bio</small></h2>
            <p>
                I am a Research Software Engineer with over fifteen years of
                experience building computational tools for the humanities and
                social sciences. My work spans web applications, data pipelines,
                natural language processing, and the long-term sustainability of
                research software — at the intersection of engineering rigour
                and humanistic inquiry.
            </p>
            <p>
                I am particularly interested in machine learning applications
                for humanities research, open-source research tools, and
                training researchers in computational methods. I previously
                worked at King's Digital Lab as Principal Research Software
                Engineer, contributing to editions, archives, prosopographies
                and computational humanities projects across history,
                literature, classics and film studies.
            </p>
        </section>

        <section aria-labelledby="projects">
            <h2 id="projects">Projects</h2>
            <ul class="projects-list">
                {
                    projects.map((p, i) => (
                        <li>
                            <ProjectItem
                                title={p.title}
                                url={p.url}
                                startYear={p.startYear}
                                endYear={p.endYear}
                                partners={p.partners}
                                summary={p.summary}
                                index={i + 1}
                            />
                        </li>
                    ))
                }
            </ul>
        </section>

        <section aria-labelledby="research">
            <h2 id="research">
                Research <small>publications &amp; essays</small>
            </h2>
            {
                publications.length === 0 ? (
                    <p>
                        Selected publications will appear here. In the meantime,
                        see my full{" "}
                        <a
                            href="https://kclpure.kcl.ac.uk/portal/en/persons/jose.m.vieira/publications/"
                            rel="noopener"
                        >
                            profile on KCL Pure
                        </a>
                        .
                    </p>
                ) : (
                    <ul class="publications-list">
                        {publications.map((p) => (
                            <PublicationItem
                                title={p.title}
                                authors={p.authors}
                                year={p.year}
                                venue={p.venue}
                                url={p.url}
                            />
                        ))}
                    </ul>
                )
            }
        </section>
    </main>

    <footer class="site">
        <a href="https://www.linkedin.com/in/jmiguelv/" rel="noopener"
            >LinkedIn</a
        >
        <a href="https://github.com/jmiguelv" rel="noopener">GitHub</a>
        <span class="colophon">
            Set in Space Grotesk &amp; IBM Plex Mono · Built with <a href="https://astro.build" rel="noopener">Astro</a> · No tracking
        </span>
    </footer>
</Base>
