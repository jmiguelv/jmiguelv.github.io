---
import { getCollection } from "astro:content";
import { Content as About } from "../content/about.md";
import Base from "../layouts/Base.astro";
import ProjectItem from "../components/ProjectItem.astro";
import PublicationItem from "../components/PublicationItem.astro";
import { sortProjects, sortPublications } from "../utils/sort";
import { version } from "../../package.json";

const projectEntries = await getCollection("projects");
const projects = projectEntries.map((e) => e.data).sort(sortProjects);

const publicationEntries = await getCollection("publications");
const publications = publicationEntries
  .map((e) => e.data)
  .sort(sortPublications);
---

<Base title="Miguel Vieira — Research Software Engineer">
  <header class="site">
    <input
      type="checkbox"
      id="theme-toggle"
      class="theme-input"
      aria-label="Toggle dark mode"
    />
    <h1 class="name">
      M<label
        for="theme-toggle"
        class="tittle"
        title="Toggle dark mode"
        aria-label="Toggle dark mode">ı</label
      >guel
      <span class="surname">Vieira</span>
    </h1>
    <p class="role">
      Research Software Engineer
      <span class="sep">+</span>
      Digital Humanities
    </p>
  </header>

  <main id="main">
    <section class="about" aria-labelledby="about">
      <h2 id="about">About</h2>
      <About />
    </section>

    <section aria-labelledby="projects">
      <h2 id="projects">Selected Work</h2>
      <ul class="projects-list">
        {
          projects.map((p) => (
            <li>
              <ProjectItem
                title={p.title}
                links={p.links}
                startYear={p.startYear}
                endYear={p.endYear}
                summary={p.summary}
              />
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="publications">
      <h2 id="publications">Research Outputs</h2>
      <ul class="publications-list">
        {
          publications.map((p) => (
            <li>
              <PublicationItem
                title={p.title}
                authors={p.authors}
                year={p.year}
                venue={p.venue}
                url={p.url}
                type={p.type}
              />
            </li>
          ))
        }
      </ul>
    </section>
  </main>

  <footer class="site">
    <nav aria-label="Social">
      <ul class="social">
        <li>
          <a href="mailto:jmiguelv.github.io.unafraid248@passinbox.com">Email</a
          >
        </li>
        <li><a href="https://github.com/jmiguelv" rel="external">GitHub</a></li>
        <li>
          <a href="https://www.linkedin.com/in/jmiguelv/" rel="external"
            >LinkedIn</a
          >
        </li>
      </ul>
    </nav>
    <span class="colophon">
      <code>v{version}</code> — Built with <a
        href="https://astro.build"
        rel="external">Astro</a
      >
    </span>
  </footer>
</Base>
