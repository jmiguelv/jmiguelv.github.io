---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Page Not Found">
  <header class="site">
    <h1 class="name">404</h1>
    <p class="role">
      Page not found <span class="sep">+</span> Miguel Vieira
    </p>
  </header>

  <main>
    <section aria-labelledby="not-found">
      <h2 id="not-found">Not Found</h2>
      <p>The page you're looking for doesn't exist or has moved.</p>
      <p>
        <a href="/">Return to the home page</a>
      </p>
    </section>
  </main>
</Base>
