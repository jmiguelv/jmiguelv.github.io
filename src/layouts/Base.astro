---
import { getImage } from "astro:assets";
import "../styles/global.css";
import ogImageAsset from "../assets/og-image.jpg";

interface Props {
  title: string;
  description?: string;
  canonical?: boolean;
}

const {
  title,
  description = "Miguel Vieira — Research Software Engineer.",
  canonical = true,
} = Astro.props;

/* JPEG rather than WebP: not all social crawlers render WebP previews. */
const optimizedOgImage = await getImage({
  src: ogImageAsset,
  width: 1200,
  format: "jpg",
  quality: 80,
});
const ogImage = new URL(optimizedOgImage.src, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* Only the latin subsets render at first paint — latin-ext loads on
    demand via @font-face unicode-range */
    }
    <link
      rel="preload"
      href="/fonts/space-grotesk-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/space-mono-latin-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    {canonical && <link rel="canonical" href={Astro.url} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Miguel Vieira" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {
      /* Privacy-friendly, cookieless analytics via Umami Cloud — production only,
       so dev traffic doesn't pollute stats */
    }
    {
      import.meta.env.PROD && (
        <script
          defer
          src="https://cloud.umami.is/script.js"
          data-website-id="810d6625-4938-4993-8440-4e6ac1d49091"
        />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="wrap">
      <slot />
    </div>
  </body>
</html>
