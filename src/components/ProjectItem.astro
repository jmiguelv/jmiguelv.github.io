---
interface Link {
  url: string;
  label: string;
}

interface Props {
  title: string;
  links: Link[];
  startYear: number | null;
  endYear: number | null;
  summary: string;
}

const { title, links, startYear, endYear, summary } = Astro.props;

function yearRange(start: number | null, end: number | null): string {
  if (start === null && end === null) return '—';
  if (start === null) return `→${end}`;
  if (end === null) return `${start}→`;
  if (start === end) return `${start}`;
  return `${start}–${end}`;
}
---

<details>
  <summary>
    <span class="marker">+</span>
    <span class="title">{title}</span>
  </summary>
  <div class="body">
    <p class="years">{yearRange(startYear, endYear)}</p>
    <p>{summary}</p>
    <ul class="links">
      {links.map((l) => (
        <li>
          <a class="visit" href={l.url} rel="noopener" aria-label={`${title} — ${l.label}`}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</details>
