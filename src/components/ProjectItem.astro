---
interface Link {
  url: string;
  label: string;
}

interface Props {
  title: string;
  links: Link[];
  startYear: number | null;
  endYear: number | null;
  summary: string;
}

const { title, links, startYear, endYear, summary } = Astro.props;

function yearRange(start: number | null, end: number | null): string {
  if (start === null && end === null) return "—";
  if (start === null) return `→${end}`;
  if (end === null) return `${start}→`;
  if (start === end) return `${start}`;
  return `${start}–${end}`;
}

function yearDatetime(start: number | null, end: number | null): string | null {
  if (start === null && end === null) return null;
  if (start === null) return String(end);
  if (end === null) return String(start);
  if (start === end) return String(start);
  return `${start}/${end}`;
}

const dt = yearDatetime(startYear, endYear);
---

<details>
  <summary>
    <span class="marker" aria-hidden="true">+</span>
    <span class="title">{title}</span>
  </summary>
  <div class="body">
    <p class="years">
      {dt ? <time datetime={dt}>{yearRange(startYear, endYear)}</time> : "—"}
    </p>
    <p>{summary}</p>
    <ul class="links">
      {
        links.map((l) => (
          <li>
            <a
              class="visit"
              href={l.url}
              rel="external"
              aria-label={`${title} — ${l.label}`}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</details>
