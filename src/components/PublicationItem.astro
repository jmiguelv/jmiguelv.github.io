---
interface Props {
  title: string;
  authors: string[];
  year: number;
  venue: string;
  url?: string;
}

const { title, authors, year, venue, url } = Astro.props;
---

<details>
  <summary>
    <span class="marker" aria-hidden="true">+</span>
    <span class="title">{title}</span>
  </summary>
  <div class="body">
    <p class="years">
      <time datetime={String(year)}>{year}</time>{venue && ` · ${venue}`}
    </p>
    <p>{authors.join(', ')}</p>
    {url && (
      <ul class="links">
        <li>
          <a class="visit" href={url} rel="external" aria-label={`View publication — ${title}${venue ? ` (${venue})` : ''}`}>
            View publication
          </a>
        </li>
      </ul>
    )}
  </div>
</details>
