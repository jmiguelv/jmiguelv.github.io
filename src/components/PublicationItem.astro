---
interface Props {
  title: string;
  authors: string[];
  year: number;
  venue: string;
  url?: string;
}

const { title, authors, year, venue, url } = Astro.props;
---

<details>
  <summary>
    <span class="marker">+</span>
    <span class="title">{title}</span>
  </summary>
  <div class="body">
    <p class="years">{venue ? `${year} · ${venue}` : year}</p>
    <p>{authors.join(', ')}</p>
    {url && (
      <ul class="links">
        <li>
          <a class="visit" href={url} rel="noopener" aria-label={`${title} — ${venue}`}>
            View publication
          </a>
        </li>
      </ul>
    )}
  </div>
</details>
